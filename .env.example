# ===========================================
# Serverlog - Environment Configuration
# ===========================================
# The install script generates this file automatically with secure defaults.
# For manual setup: cp .env.example .env

# -------------------------------------------
# Domain (used by Caddy reverse proxy)
# -------------------------------------------
# Set to your server's domain for automatic HTTPS via Let's Encrypt.
# Use "localhost" for local/testing (Caddy serves HTTP only).
DOMAIN=localhost

# TLS mode for Caddy:
#   (empty) = Caddy auto-provisions a Let's Encrypt certificate (default)
#   off     = Disable Caddy TLS (use when Cloudflare proxy / orange cloud handles HTTPS)
CADDY_TLS=

# -------------------------------------------
# Security
# -------------------------------------------
# Auto-generated by install script. To generate manually:
#   openssl rand -base64 32
JWT_SECRET=change-this-to-a-secure-random-string

# -------------------------------------------
# Database
# -------------------------------------------
POSTGRES_USER=serverlog
POSTGRES_PASSWORD=change-this-to-a-secure-password
POSTGRES_DB=serverlog

# -------------------------------------------
# Internal ports (no need to change these)
# -------------------------------------------
BACKEND_PORT=3010
FRONTEND_PORT=3011

# -------------------------------------------
# External ports (Caddy reverse proxy)
# -------------------------------------------
HTTP_PORT=80
HTTPS_PORT=443
