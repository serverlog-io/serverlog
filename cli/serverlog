#!/usr/bin/env bash
#
# serverlog — manage a self-hosted Serverlog installation
#
set -euo pipefail

VERSION="0.1.0"

# Read persisted install location if SERVERLOG_HOME isn't set via env.
# scripts/install.sh writes /etc/serverlog.conf on install.
if [ -z "${SERVERLOG_HOME:-}" ]; then
    for cfg in /etc/serverlog.conf "$HOME/.config/serverlog/config"; do
        if [ -r "$cfg" ]; then
            # shellcheck source=/dev/null
            . "$cfg"
            break
        fi
    done
fi

# Defaults match scripts/install.sh
SERVERLOG_HOME="${SERVERLOG_HOME:-$HOME/serverlog}"
SERVERLOG_BRANCH="${SERVERLOG_BRANCH:-main}"
COMPOSE_FILE="${SERVERLOG_COMPOSE_FILE:-docker-compose.prod.yml}"

# ─── Colors (TTY only) ────────────────────────────────────────────────
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    RED=$(printf '\033[0;31m')
    GREEN=$(printf '\033[0;32m')
    YELLOW=$(printf '\033[1;33m')
    BLUE=$(printf '\033[0;34m')
    BOLD=$(printf '\033[1m')
    NC=$(printf '\033[0m')
else
    RED= GREEN= YELLOW= BLUE= BOLD= NC=
fi

log()   { printf "%s[serverlog]%s %s\n" "$BLUE"   "$NC" "$1"; }
ok()    { printf "%s[serverlog]%s %s\n" "$GREEN"  "$NC" "$1"; }
warn()  { printf "%s[serverlog]%s %s\n" "$YELLOW" "$NC" "$1" >&2; }
err()   { printf "%s[serverlog]%s %s\n" "$RED"    "$NC" "$1" >&2; }
die()   { err "$1"; exit 1; }

# ─── Preconditions ────────────────────────────────────────────────────
DC=()

need_docker() {
    command -v docker >/dev/null 2>&1 || die "docker is not installed or not in PATH"
    docker info >/dev/null 2>&1 || die "docker daemon is not running (try sudo?)"
}

need_compose() {
    if docker compose version >/dev/null 2>&1; then
        DC=(docker compose)
    elif command -v docker-compose >/dev/null 2>&1; then
        DC=(docker-compose)
    else
        die "docker compose is not installed"
    fi
}

need_home() {
    [ -d "$SERVERLOG_HOME" ] \
        || die "SERVERLOG_HOME=$SERVERLOG_HOME does not exist (override with: export SERVERLOG_HOME=/path)"
    [ -f "$SERVERLOG_HOME/$COMPOSE_FILE" ] \
        || die "$SERVERLOG_HOME/$COMPOSE_FILE not found. Is this a Serverlog install?"
}

dc() {
    "${DC[@]}" -f "$COMPOSE_FILE" "$@"
}

# ─── Commands ─────────────────────────────────────────────────────────
cmd_update() {
    need_docker; need_compose; need_home
    cd "$SERVERLOG_HOME"

    if [ -d .git ]; then
        if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
            die "uncommitted changes in $SERVERLOG_HOME — stash or revert before updating"
        fi
        log "Pulling latest source from origin/$SERVERLOG_BRANCH..."
        git fetch origin "$SERVERLOG_BRANCH" || die "git fetch failed"
        git checkout "$SERVERLOG_BRANCH" >/dev/null 2>&1 || die "git checkout failed"
        git pull --ff-only origin "$SERVERLOG_BRANCH" || die "git pull --ff-only failed"
    else
        warn "Not a git repo — skipping source pull"
    fi

    log "Pulling updated base images..."
    dc pull

    log "Rebuilding and restarting containers..."
    dc up -d --build

    ok "Update complete"
}

cmd_start() {
    need_docker; need_compose; need_home
    cd "$SERVERLOG_HOME"
    log "Starting Serverlog..."
    dc up -d
    ok "Serverlog is running"
}

cmd_stop() {
    need_docker; need_compose; need_home
    cd "$SERVERLOG_HOME"
    log "Stopping Serverlog..."
    dc down
    ok "Serverlog is stopped"
}

cmd_restart() {
    need_docker; need_compose; need_home
    cd "$SERVERLOG_HOME"
    log "Restarting Serverlog..."
    dc restart
    ok "Serverlog restarted"
}

cmd_status() {
    need_docker; need_compose; need_home
    cd "$SERVERLOG_HOME"
    dc ps
}

cmd_logs() {
    need_docker; need_compose; need_home
    cd "$SERVERLOG_HOME"
    if [ "$#" -gt 0 ]; then
        dc logs -f --tail=200 "$@"
    else
        dc logs -f --tail=200
    fi
}

cmd_uninstall() {
    local yes=false
    for arg in "$@"; do
        case "$arg" in
            -y|--yes) yes=true ;;
        esac
    done

    printf "\n%sThis will PERMANENTLY DELETE:%s\n" "$RED" "$NC"
    printf "  • All Serverlog containers and volumes (database, events, users, API keys)\n"
    printf "  • Install directory:  %s\n" "$SERVERLOG_HOME"
    printf "  • CLI binary:         /usr/local/bin/serverlog (and config)\n"
    printf "  • Docker images:      serverlog-backend, serverlog-frontend\n"
    printf "\n%sData cannot be recovered.%s\n\n" "$YELLOW" "$NC"

    if ! $yes; then
        read -rp "Type 'uninstall' to confirm: " confirm </dev/tty || confirm=""
        if [ "$confirm" != "uninstall" ]; then
            log "Aborted. Nothing was removed."
            return 0
        fi
    fi

    # 1. Stop containers + drop volumes
    if [ -d "$SERVERLOG_HOME" ] && [ -f "$SERVERLOG_HOME/$COMPOSE_FILE" ]; then
        if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
            need_compose
            cd "$SERVERLOG_HOME"
            log "Stopping containers and removing volumes..."
            dc down -v 2>/dev/null || true
        else
            warn "Docker unavailable — skipping container/volume cleanup"
        fi
    fi

    # 2. Remove install dir
    if [ -d "$SERVERLOG_HOME" ]; then
        log "Removing install directory: $SERVERLOG_HOME"
        cd /tmp
        rm -rf "$SERVERLOG_HOME"
    fi

    # 3. Remove CLI binary and config
    log "Removing CLI binary and config..."
    local rm_sudo=""
    if [ "$(id -u)" -ne 0 ] && command -v sudo >/dev/null 2>&1; then
        rm_sudo="sudo"
    fi
    $rm_sudo rm -f /usr/local/bin/serverlog 2>/dev/null || true
    $rm_sudo rm -f /etc/serverlog.conf 2>/dev/null || true
    rm -f "$HOME/.local/bin/serverlog" 2>/dev/null || true
    rm -rf "$HOME/.config/serverlog" 2>/dev/null || true

    # 4. Remove Docker images
    if command -v docker >/dev/null 2>&1; then
        log "Removing Serverlog Docker images..."
        docker rmi -f serverlog-backend serverlog-frontend 2>/dev/null || true
    fi

    ok "Serverlog has been uninstalled."
    printf "\nNot removed (manual cleanup if you also want them gone):\n"
    printf "  • Docker engine itself\n"
    printf "  • Cloudflare DNS records / SSL/TLS settings\n"
    printf "  • UFW rules for ports 80/443\n"

    # If the caller's shell is inside the now-deleted install dir, its cwd is
    # stale — git/bash/etc. will fail with "Unable to read current working
    # directory". We can't change the parent shell's cwd from here.
    local parent_cwd
    parent_cwd=$(readlink "/proc/$PPID/cwd" 2>/dev/null || echo "")
    if [ -n "$parent_cwd" ] && [ ! -d "$parent_cwd" ]; then
        printf "\n%sYour current shell directory was just removed.%s\n" "$YELLOW" "$NC"
        printf "Run %scd ~%s before continuing.\n" "$BOLD" "$NC"
    fi
}

cmd_version() {
    printf "%sserverlog cli%s %s\n" "$BOLD" "$NC" "$VERSION"
    printf "install:  %s\n" "$SERVERLOG_HOME"
    if [ -d "$SERVERLOG_HOME/.git" ]; then
        local commit branch
        commit=$(git -C "$SERVERLOG_HOME" rev-parse --short HEAD 2>/dev/null || echo "unknown")
        branch=$(git -C "$SERVERLOG_HOME" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
        printf "revision: %s (%s)\n" "$commit" "$branch"
    else
        printf "revision: (not a git repo)\n"
    fi
}

cmd_help() {
    cat <<EOF
${BOLD}serverlog${NC} — manage a self-hosted Serverlog installation

${BOLD}USAGE${NC}
  serverlog <command> [args]

${BOLD}COMMANDS${NC}
  update            Pull latest source and rebuild containers
  start             Start all services
  stop              Stop all services
  restart           Restart all services
  status            Show running containers
  logs [svc...]     Tail logs (optional: postgres, backend, frontend, caddy)
  version           Show CLI version and install info
  uninstall [-y]    Remove containers, volumes, install dir, CLI and config
  help              Show this help

${BOLD}ENVIRONMENT${NC}
  SERVERLOG_HOME           Install path (default: \$HOME/serverlog)
  SERVERLOG_BRANCH         Git branch to track (default: main)
  SERVERLOG_COMPOSE_FILE   Compose file (default: docker-compose.prod.yml)
  NO_COLOR=1               Disable ANSI colors

${BOLD}EXAMPLES${NC}
  serverlog update
  serverlog logs backend
  SERVERLOG_HOME=/opt/serverlog serverlog status
EOF
}

# ─── Dispatch ─────────────────────────────────────────────────────────
case "${1:-help}" in
    update)               shift; cmd_update "$@" ;;
    start|up)             shift; cmd_start "$@" ;;
    stop|down)            shift; cmd_stop "$@" ;;
    restart)              shift; cmd_restart "$@" ;;
    status|ps)            shift; cmd_status "$@" ;;
    logs)                 shift; cmd_logs "$@" ;;
    uninstall)            shift; cmd_uninstall "$@" ;;
    version|--version|-v) cmd_version ;;
    help|--help|-h|"")    cmd_help ;;
    *)                    err "Unknown command: $1"; printf "\n"; cmd_help; exit 1 ;;
esac
